{
  "manifest_version": 3,
  "name": "Deja View",
  "version": "1.0.1",
  "description": "Visual regression testing made simple. Capture, compare, and spot pixel differences — no CI required.",
  "author": "Keshav Agarwal",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
